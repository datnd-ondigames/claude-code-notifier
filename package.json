{
  "name": "claude-notify-native",
  "displayName": "Claude Notify Native",
  "description": "Claude Code notifier with native OS notifications, dashboard, history, and guided hook install.",
  "version": "2.1.0",
  "publisher": "felix",
  "author": { "name": "Erdem Giray" },
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/egiray/claude-code-notifier" },
  "keywords": ["claude", "claude-code", "anthropic", "ai", "notifications", "hooks", "productivity"],
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      { "command": "claude-notifier.notify",           "title": "Claude Notifier: Send Test Notification" },
      { "command": "claudeNotifier.openPanel",         "title": "Claude Notifier: Open Panel" },
      { "command": "claudeNotifier.openDashboard",     "title": "Claude Notifier: Open Dashboard in Browser" },
      { "command": "claudeNotifier.runWizard",         "title": "Claude Notifier: Run Setup Wizard" },
      { "command": "claudeNotifier.installHooks",      "title": "Claude Notifier: Install Hooks" },
      { "command": "claudeNotifier.removeHooks",       "title": "Claude Notifier: Remove Hooks" },
      { "command": "claudeNotifier.clearHistory",      "title": "Claude Notifier: Clear History" },
      { "command": "claudeNotifier.showLog",           "title": "Claude Notifier: Show Log File" }
    ],
    "configuration": {
      "title": "Claude Code Notifier",
      "properties": {
        "claudeNotifier.enabled":             { "type": "boolean", "default": true },
        "claudeNotifier.logPath":             { "type": "string",  "default": "", "description": "Override log path. Empty uses ~/.claude/notifier.log." },
        "claudeNotifier.suppressWhenFocused": { "type": "boolean", "default": false },
        "claudeNotifier.showAllWorkspaces":   { "type": "boolean", "default": false },

        "claudeNotifier.events.permission_prompt.enabled":  { "type": "boolean", "default": true },
        "claudeNotifier.events.permission_prompt.severity": { "type": "string", "enum": ["info","warning","error"], "default": "warning" },
        "claudeNotifier.events.permission_prompt.sound":    { "type": "boolean", "default": true },

        "claudeNotifier.events.elicitation_dialog.enabled":  { "type": "boolean", "default": true },
        "claudeNotifier.events.elicitation_dialog.severity": { "type": "string", "enum": ["info","warning","error"], "default": "warning" },
        "claudeNotifier.events.elicitation_dialog.sound":    { "type": "boolean", "default": true },

        "claudeNotifier.events.idle_prompt.enabled":  { "type": "boolean", "default": false },
        "claudeNotifier.events.idle_prompt.severity": { "type": "string", "enum": ["info","warning","error"], "default": "info" },
        "claudeNotifier.events.idle_prompt.sound":    { "type": "boolean", "default": false },

        "claudeNotifier.events.stop.enabled":  { "type": "boolean", "default": false },
        "claudeNotifier.events.stop.severity": { "type": "string", "enum": ["info","warning","error"], "default": "info" },
        "claudeNotifier.events.stop.sound":    { "type": "boolean", "default": false },

        "claudeNotifier.events.subagent_stop.enabled":  { "type": "boolean", "default": false },
        "claudeNotifier.events.subagent_stop.severity": { "type": "string", "enum": ["info","warning","error"], "default": "info" },
        "claudeNotifier.events.subagent_stop.sound":    { "type": "boolean", "default": false },

        "claudeNotifier.history.maxEntries":      { "type": "number",  "default": 500, "minimum": 50, "maximum": 10000 },
        "claudeNotifier.statusBar.enabled":       { "type": "boolean", "default": true },
        "claudeNotifier.statusBar.clickAction":   { "type": "string",  "enum": ["dashboard","panel","quickPick"], "default": "dashboard" },
        "claudeNotifier.actions.showFocusWindow": { "type": "boolean", "default": true },
        "claudeNotifier.actions.showOpenTerminal":{ "type": "boolean", "default": true },
        "claudeNotifier.actions.showSnooze":      { "type": "boolean", "default": false },
        "claudeNotifier.snoozeMinutes":           { "type": "number",  "default": 5, "minimum": 1, "maximum": 60 },
        "claudeNotifier.server.enabled":          { "type": "boolean", "default": true },
        "claudeNotifier.server.port":             { "type": "number",  "default": 0, "description": "0 = auto-pick starting 37100." },
        "claudeNotifier.osNotifications.enabled":        { "type": "boolean", "default": false, "description": "Show native OS notifications (Linux: gdbus/libnotify, macOS: osascript). Click focuses the VS Code window matching the event's workspace." },
        "claudeNotifier.osNotifications.replaceToast":   { "type": "boolean", "default": true,  "description": "When OS notifications fire, suppress the in-editor VS Code toast to avoid double-notify." },
        "claudeNotifier.osNotifications.requireDismiss": { "type": "boolean", "default": false, "description": "Keep OS notifications visible until dismissed. Sends expire_timeout=0 and urgency=critical (GNOME keeps these sticky). Errors are always critical regardless of this setting." }
      }
    }
  }
}
